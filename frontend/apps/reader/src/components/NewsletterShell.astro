---
import type { PublicWorkspaceDto } from "@rapid/api-client";

interface Props {
  workspace: PublicWorkspaceDto;
}

const { workspace } = Astro.props;
---
<header class="newsletter-header">
  <div class="container">
    <p class="muted">/{workspace.slug}</p>
    <h1>{workspace.name}</h1>
    {workspace.description && <p class="muted" style="max-width: 680px; font-size: 1.15rem;">{workspace.description}</p>}
  </div>
</header>
