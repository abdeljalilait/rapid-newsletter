---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Rapid Newsletter">
  <main class="container" id="newsletters" style="padding: 72px 0;">
    <h1 style="font-size: clamp(42px, 8vw, 88px); margin: 0 0 16px;">Newsletter directory</h1>
    <p class="muted" style="max-width: 640px;">Open a workspace by URL, for example <code>/dotnet-weekly</code>.</p>
  </main>
</BaseLayout>
